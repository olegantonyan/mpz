	depends = libmpdclient
	depends = cpptrace
	provides = <%= pkgname %>
	source = <%= pkgname %>-<%= pkgver %>-<%= pkgrel %>.zip::<%= source %>
	sha256sums = <%= sha256sums %>

pkgname = <%= pkgname %>
