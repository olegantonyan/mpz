pkgbase = <%= pkgname %>
	pkgdesc = Music player for the large local collections
	pkgver = <%= pkgver %>
	pkgrel = <%= pkgrel %>
	url = https://github.com/olegantonyan/mpz
	arch = x86_64
	license = GPL3
	makedepends = cmake
	depends = qt6-multimedia
	depends = qt6-svg
	depends = hicolor-icon-theme
	depends = yaml-cpp
