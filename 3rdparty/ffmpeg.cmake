# FFMPEG (vendored, static, LGPL)
#
# Builds a trimmed, statically-linked, LGPL-only FFmpeg from the FULL source
# tree vendored in 3rdparty/ffmpeg-<version>/ (same versioned-folder convention
# as taglib-2.3, yaml-cpp-0.9.0, libmpdclient-2.23) and exposes it as the
# INTERFACE target `ffmpeg_static` (include dir + the four audio static archives
# + their per-platform transitive deps).
#
# FFmpeg ships no CMake build, so we drive its own ./configure && make via
# ExternalProject. NOTHING IS DOWNLOADED at build time -- it builds out-of-tree
# from the committed source. The build adds a few minutes to a clean build.
#
# Requires: a C toolchain, `make`, and an assembler (nasm/yasm) unless
# -DMPZ_FFMPEG_DISABLE_ASM=ON. Set -DUSE_SYSTEM_FFMPEG=ON to skip all of this
# and link the OS-provided FFmpeg instead (see CMakeLists.txt).
#
# Cross builds (macOS universal, Windows/mingw) need extra configure flags
# (--arch/--target-os/--cross-prefix/--cc); those are layered in by the
# packaging scripts and are intentionally not hard-coded here.

include(ExternalProject)
include(ProcessorCount)

set(FFMPEG_VERSION 8.1.1 CACHE STRING "Vendored FFmpeg version")
set(_ff_src "${CMAKE_CURRENT_SOURCE_DIR}/3rdparty/ffmpeg-${FFMPEG_VERSION}")
if(NOT EXISTS "${_ff_src}/configure")
  message(FATAL_ERROR
    "Vendored FFmpeg source not found at ${_ff_src}.\n"
    "Expected the full FFmpeg ${FFMPEG_VERSION} source tree committed there, "
    "or configure with -DUSE_SYSTEM_FFMPEG=ON to use the OS FFmpeg.")
endif()

option(MPZ_FFMPEG_HTTPS      "Build vendored FFmpeg with TLS (https radio support)" ON)
option(MPZ_FFMPEG_DISABLE_ASM "Build vendored FFmpeg without x86 assembly (no nasm/yasm needed)" OFF)

ProcessorCount(_ff_jobs)
if(_ff_jobs EQUAL 0)
  set(_ff_jobs 2)
endif()

find_program(MAKE_EXECUTABLE NAMES make gmake mingw32-make REQUIRED)
if(NOT MPZ_FFMPEG_DISABLE_ASM)
  find_program(_ff_asm_tool NAMES nasm yasm)
  if(NOT _ff_asm_tool)
    message(WARNING
      "nasm/yasm not found - the vendored FFmpeg build will fail. "
      "Install nasm (recommended) or configure with -DMPZ_FFMPEG_DISABLE_ASM=ON.")
  endif()
endif()

set(_ff_root    "${CMAKE_BINARY_DIR}/_deps/ffmpeg")
set(_ff_install "${_ff_root}/install")
set(_ff_lib     "${_ff_install}/lib")
set(_ff_inc     "${_ff_install}/include")

# --- configure flags ---------------------------------------------------------
# Audio-only, static, self-contained build. We strip every subsystem an audio
# player never touches (video/image decoders, hwaccel, muxers/encoders, filters,
# devices, compression/text libs) and enable only audio decoders/demuxers/
# parsers. The component lists below were generated by intersecting a curated
# audio set with this FFmpeg's actual `configure --list-*` names, so they only
# contain valid names; regenerate them if you bump FFMPEG_VERSION.
set(_ff_configure
  "<SOURCE_DIR>/configure"
  "--prefix=${_ff_install}"
  --disable-shared --enable-static --enable-pic
  # Don't auto-pull host libraries (VA-API/VDPAU/Vulkan/libdrm hwaccel, zlib,
  # etc.). This keeps the build self-contained and reproducible regardless of
  # what dev packages happen to be installed, and avoids dangling references to
  # libva/libvdpau/libdrm/libvulkan at the final link.
  --disable-autodetect
  --disable-programs --disable-doc
  --disable-avdevice --disable-swscale --disable-avfilter
  --disable-encoders --disable-muxers --disable-devices --disable-filters --disable-bsfs
  --disable-hwaccels --disable-vaapi --disable-vdpau --disable-vulkan --disable-v4l2-m2m
  --disable-zlib --disable-bzlib --disable-lzma --disable-iconv
  --disable-debug --disable-gpl --disable-nonfree
  --enable-network
)

# Audio-only component selection: drop every decoder/demuxer/parser, then
# re-enable just the audio ones. Bitstream filters are disabled above too -- one
# of them (dts2pts) selects the HEVC video parser by default; any BSF a demuxer
# genuinely needs is force-selected back on. Protocols are left at their
# defaults (--disable-autodetect already pruned the external-lib ones).
set(_ff_decoders "aac,aac_fixed,aac_latm,ac3,ac3_fixed,adpcm_4xm,adpcm_adx,adpcm_afc,adpcm_agm,adpcm_aica,adpcm_argo,adpcm_circus,adpcm_ct,adpcm_dtk,adpcm_ea,adpcm_ea_maxis_xa,adpcm_ea_r1,adpcm_ea_r2,adpcm_ea_r3,adpcm_ea_xas,adpcm_g722,adpcm_g726,adpcm_g726le,adpcm_ima_acorn,adpcm_ima_alp,adpcm_ima_amv,adpcm_ima_apc,adpcm_ima_apm,adpcm_ima_cunning,adpcm_ima_dat4,adpcm_ima_dk3,adpcm_ima_dk4,adpcm_ima_ea_eacs,adpcm_ima_ea_sead,adpcm_ima_escape,adpcm_ima_hvqm2,adpcm_ima_hvqm4,adpcm_ima_iss,adpcm_ima_magix,adpcm_ima_moflex,adpcm_ima_mtf,adpcm_ima_oki,adpcm_ima_pda,adpcm_ima_qt,adpcm_ima_qt_at,adpcm_ima_rad,adpcm_ima_smjpeg,adpcm_ima_ssi,adpcm_ima_wav,adpcm_ima_ws,adpcm_ima_xbox,adpcm_ms,adpcm_mtaf,adpcm_n64,adpcm_psx,adpcm_psxc,adpcm_sanyo,adpcm_sbpro_2,adpcm_sbpro_3,adpcm_sbpro_4,adpcm_swf,adpcm_thp,adpcm_thp_le,adpcm_vima,adpcm_xa,adpcm_xmd,adpcm_yamaha,adpcm_zork,alac,als,amrnb,amrwb,apac,ape,aptx,aptx_hd,atrac1,atrac3,atrac3al,atrac3p,atrac3pal,atrac9,binkaudio_dct,binkaudio_rdft,bmv_audio,comfortnoise,cook,dca,dfpwm,dolby_e,dsd_lsbf,dsd_lsbf_planar,dsd_msbf,dsd_msbf_planar,dsicinaudio,dst,eac3,fastaudio,flac,ftr,g723_1,g729,gsm,gsm_ms,hca,hcom,ilbc,imc,mace3,mace6,metasound,mlp,mp1,mp1float,mp2,mp2float,mp3,mp3adu,mp3adufloat,mp3float,mp3on4,mp3on4float,mpc7,mpc8,nellymoser,on2avc,opus,osq,paf_audio,pcm_alaw,pcm_alaw_at,pcm_bluray,pcm_dvd,pcm_f16le,pcm_f24le,pcm_f32be,pcm_f32le,pcm_f64be,pcm_f64le,pcm_lxf,pcm_mulaw,pcm_mulaw_at,pcm_s16be,pcm_s16be_planar,pcm_s16le,pcm_s16le_planar,pcm_s24be,pcm_s24daud,pcm_s24le,pcm_s24le_planar,pcm_s32be,pcm_s32le,pcm_s32le_planar,pcm_s64be,pcm_s64le,pcm_s8,pcm_s8_planar,pcm_sga,pcm_u16be,pcm_u16le,pcm_u24be,pcm_u24le,pcm_u32be,pcm_u32le,pcm_u8,pcm_vidc,qcelp,qdm2,qdmc,ra_144,ra_288,ralf,rka,s302m,sbc,shorten,sipr,siren,smackaud,sonic,speex,tak,truehd,tta,twinvq,vorbis,wavarc,wavpack,wmalossless,wmapro,wmav1,wmav2,wmavoice,ws_snd1,xma1,xma2")
set(_ff_demuxers "aac,aax,ac3,aiff,amr,apac,ape,asf,au,bink,caf,dsf,dts,dtshd,eac3,flac,gsm,hls,iff,matroska,mlp,mov,mp3,mpc,mpegts,ogg,rm,s337m,smacker,spdif,tak,truehd,tta,voc,w64,wav,wavarc,wsd,wv,xwma")
set(_ff_parsers  "aac,aac_latm,ac3,amr,cook,dca,dolby_e,flac,gsm,mlp,mpegaudio,opus,sbc,tak,vorbis,xma")
list(APPEND _ff_configure
  --disable-decoders --enable-decoder=${_ff_decoders}
  --disable-demuxers --enable-demuxer=${_ff_demuxers}
  --disable-parsers  --enable-parser=${_ff_parsers}
)

# --disable-autodetect also turns off thread support, so re-enable it. On
# Windows FFmpeg uses the built-in w32threads (no external dependency).
if(NOT WIN32)
  list(APPEND _ff_configure --enable-pthreads)
endif()

if(MPZ_FFMPEG_DISABLE_ASM)
  list(APPEND _ff_configure --disable-x86asm)
endif()

set(_ff_link_openssl OFF)
if(MPZ_FFMPEG_HTTPS)
  if(APPLE)
    list(APPEND _ff_configure --enable-securetransport)
  elseif(WIN32)
    list(APPEND _ff_configure --enable-schannel)
  else()
    # Linux: https via the system OpenSSL when available; otherwise build
    # without https rather than failing the whole build. Install
    # libssl-dev/openssl-devel to enable https radio.
    find_package(OpenSSL)
    if(OpenSSL_FOUND)
      list(APPEND _ff_configure --enable-openssl)
      set(_ff_link_openssl ON)
    else()
      message(WARNING "OpenSSL not found: building vendored FFmpeg WITHOUT https. "
                      "Install libssl-dev/openssl-devel for https radio support.")
    endif()
  endif()
endif()

if(APPLE)
  # Drop the Apple hwaccels we don't use so we don't have to bundle their
  # frameworks (VideoToolbox/CoreMedia/CoreVideo, AudioToolbox).
  list(APPEND _ff_configure --disable-videotoolbox --disable-audiotoolbox)
endif()

set(_ff_byproducts
  "${_ff_lib}/libavformat.a"
  "${_ff_lib}/libavcodec.a"
  "${_ff_lib}/libswresample.a"
  "${_ff_lib}/libavutil.a"
)

ExternalProject_Add(ffmpeg_external
  PREFIX "${_ff_root}"
  SOURCE_DIR "${_ff_src}"        # the committed source tree
  DOWNLOAD_COMMAND ""            # nothing is fetched; build out-of-tree
  CONFIGURE_COMMAND ${_ff_configure}
  BUILD_COMMAND "${MAKE_EXECUTABLE}" "-j${_ff_jobs}"
  INSTALL_COMMAND "${MAKE_EXECUTABLE}" install
  BUILD_BYPRODUCTS ${_ff_byproducts}
  BUILD_IN_SOURCE 0
)

# The include dir must exist at configure time for INTERFACE_INCLUDE_DIRECTORIES.
file(MAKE_DIRECTORY "${_ff_inc}")

add_library(ffmpeg_static INTERFACE)
add_dependencies(ffmpeg_static ffmpeg_external)
target_include_directories(ffmpeg_static INTERFACE "${_ff_inc}")

# --- link the static archives + transitive system deps -----------------------
if(APPLE)
  # ld64 resolves intra-archive cycles without --start-group.
  target_link_libraries(ffmpeg_static INTERFACE
    "${_ff_lib}/libavformat.a"
    "${_ff_lib}/libavcodec.a"
    "${_ff_lib}/libswresample.a"
    "${_ff_lib}/libavutil.a"
    "-framework CoreFoundation"
  )
  if(MPZ_FFMPEG_HTTPS)
    target_link_libraries(ffmpeg_static INTERFACE "-framework Security")
  endif()
elseif(WIN32)
  target_link_libraries(ffmpeg_static INTERFACE
    -Wl,--start-group
    "${_ff_lib}/libavformat.a"
    "${_ff_lib}/libavcodec.a"
    "${_ff_lib}/libswresample.a"
    "${_ff_lib}/libavutil.a"
    -Wl,--end-group
    ws2_32 bcrypt
  )
  if(MPZ_FFMPEG_HTTPS)
    target_link_libraries(ffmpeg_static INTERFACE secur32)  # schannel
  endif()
else()
  find_package(Threads REQUIRED)
  target_link_libraries(ffmpeg_static INTERFACE
    -Wl,--start-group
    "${_ff_lib}/libavformat.a"
    "${_ff_lib}/libavcodec.a"
    "${_ff_lib}/libswresample.a"
    "${_ff_lib}/libavutil.a"
    -Wl,--end-group
    m Threads::Threads ${CMAKE_DL_LIBS}
  )
  if(_ff_link_openssl)
    # https via FFmpeg's openssl protocol -> link the system OpenSSL.
    # (The codec stack is static; TLS uses the OS library. For a fully static
    # Linux build, vendor mbedTLS and switch to --enable-mbedtls instead.)
    target_link_libraries(ffmpeg_static INTERFACE OpenSSL::SSL OpenSSL::Crypto)
  endif()
endif()

# Force the app link to wait for the FFmpeg build (INTERFACE-library
# add_dependencies does not reliably order consumers on every generator).
add_dependencies(${CMAKE_PROJECT_NAME} ffmpeg_external)
# ENDOF FFMPEG
