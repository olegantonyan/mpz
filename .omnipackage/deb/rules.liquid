#!/usr/bin/make -f
# debian.rules
# Be carefull, this is a Makefile, so the indents are tabs and not spaces!
# -*- makefile -*-

%:
	dh $@

# SENTRY_DSN is public (clients embed it). Set to the project DSN from sentry.io
# to enable crash reporting; empty disables it at compile time.
override_dh_auto_configure:
	cmake -DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DSENTRY_DSN="" {{ CMAKE_EXTRA_CLI }}

# Upload debug symbols to Sentry after dh_strip splits DWARF into
# debian/mpz-dbgsym/usr/lib/debug/. Silent no-op when SENTRY_AUTH_TOKEN is unset.
override_dh_strip:
	dh_strip --automatic-dbgsym
	./scripts/upload-symbols.sh debian/ || true
