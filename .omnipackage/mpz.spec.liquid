Name:       mpz
Version:    {{ version }}
Release:    1%{?dist}
Summary:    {{ summary }}
License:    GPL-3.0-or-later
URL:        {{ homepage }}
Source0:    {{ source_folder_name }}.tar.gz
Vendor:     OmniPackage

BuildRequires: {{ build_dependencies | join: ' ' }}
{%- if runtime_dependencies %}
Requires:      {{ runtime_dependencies | join: ' ' }}
{%- endif %}

%global debug_package %{nil}
%global _build_id_links none

%description
{{ description }}


%prep
%setup -q


%build
cmake -S . -B _build \
  -DCMAKE_BUILD_TYPE=Release \
  -DCMAKE_INSTALL_PREFIX=%{_prefix} \
  -DPACKAGE_VERSION={{ version }} \
  {{ CMAKE_EXTRA_CLI }}
cmake --build _build %{?_smp_mflags}


%install
DESTDIR=%{buildroot} cmake --install _build


%files
%license license.txt
%{_bindir}/%{name}
%{_datadir}/applications/%{name}.desktop
%{_datadir}/metainfo/org.mpz_player.mpz.metainfo.xml
%{_datadir}/icons/hicolor/scalable/apps/%{name}.svg
%{_datadir}/icons/hicolor/*/apps/%{name}.png


%changelog
* Sun Aug 9 2020 {{ maintainer }}
- First public release
